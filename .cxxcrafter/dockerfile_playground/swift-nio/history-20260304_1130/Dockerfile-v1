FROM gcr.io/oss-fuzz-base/base-builder@sha256:1051d1a0a51f82987e4fa36f85dd8cee525df635f8523ac35575086979625e67

ENV DEBIAN_FRONTEND=noninteractive

# Install Swift dependencies and required packages
RUN apt-get update && apt-get install -y \
    git \
    curl \
    libatomic1 \
    libxml2 \
    netcat-openbsd \
    lsof \
    perl \
    clang \
    cmake \
    ninja-build \
    pkg-config \
    libblocksruntime-dev \
    libcurl4-openssl-dev \
    libedit-dev \
    libicu-dev \
    libncurses5-dev \
    libsqlite3-dev \
    libxml2-dev \
    libz-dev \
    tzdata \
    unzip \
    wget \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Install Swift toolchain
ENV SWIFT_VERSION=5.7.3
ENV SWIFT_PLATFORM=ubuntu22.04
ENV SWIFT_BRANCH=swift-${SWIFT_VERSION}-release
ENV SWIFT_WEBROOT=https://download.swift.org

RUN SWIFT_WEBDIR="$SWIFT_WEBROOT/$SWIFT_BRANCH/$(echo $SWIFT_PLATFORM | tr -d .)" \
    && SWIFT_BIN_URL="$SWIFT_WEBDIR/swift-${SWIFT_VERSION}-RELEASE/swift-${SWIFT_VERSION}-RELEASE-${SWIFT_PLATFORM}.tar.gz" \
    && SWIFT_SIG_URL="$SWIFT_BIN_URL.sig" \
    && apt-get update \
    && apt-get install -y curl gnupg2 \
    && curl -fsSL "$SWIFT_BIN_URL" -o swift.tar.gz \
    && curl -fsSL "$SWIFT_SIG_URL" -o swift.tar.gz.sig \
    && export GNUPGHOME="$(mktemp -d)" \
    && curl -fsSL https://swift.org/keys/all-keys.asc | gpg --import - \
    && gpg --batch --verify swift.tar.gz.sig swift.tar.gz \
    && tar -xzf swift.tar.gz --directory / --strip-components=1 \
    && rm -rf "$GNUPGHOME" swift.tar.gz.sig swift.tar.gz \
    && chmod -R o+r /usr/lib/swift \
    && apt-get purge --auto-remove -y curl gnupg2

# Set Swift environment variables
ENV PATH="/usr/bin:${PATH}"

# Clone the repository
RUN git clone --depth 1 https://github.com/apple/swift-nio.git

# Copy the build script
COPY build.sh $SRC/

# Set working directory
WORKDIR $SRC/swift-nio