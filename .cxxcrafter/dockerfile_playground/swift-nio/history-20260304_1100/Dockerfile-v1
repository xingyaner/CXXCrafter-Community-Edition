FROM gcr.io/oss-fuzz-base/base-builder@sha256:1051d1a0a51f82987e4fa36f85dd8cee525df635f8523ac35575086979625e67

ENV DEBIAN_FRONTEND=noninteractive

# Use faster mirror and update packages
RUN sed -i 's|http://archive.ubuntu.com/ubuntu/|http://mirrors.aliyun.com/ubuntu/|g' /etc/apt/sources.list \
    && sed -i 's|http://security.ubuntu.com/ubuntu/|http://mirrors.aliyun.com/ubuntu/|g' /etc/apt/sources.list \
    && apt-get update \
    && apt-get upgrade -y

# Install essential build tools and dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    software-properties-common \
    wget \
    curl \
    git \
    libatomic1 \
    libxml2 \
    libxml2-dev \
    libcurl4-openssl-dev \
    libssl-dev \
    pkg-config \
    clang \
    cmake \
    ninja-build \
    python3 \
    python3-pip \
    lsof \
    netcat-openbsd \
    perl

# Install Swift toolchain (Swift 6.0 for latest swift-nio)
RUN wget -q https://download.swift.org/swift-6.0-release/ubuntu2204/swift-6.0-RELEASE/swift-6.0-RELEASE-ubuntu22.04.tar.gz \
    && tar xzf swift-6.0-RELEASE-ubuntu22.04.tar.gz \
    && mv swift-6.0-RELEASE-ubuntu22.04 /usr/local/swift \
    && rm swift-6.0-RELEASE-ubuntu22.04.tar.gz

# Add Swift to PATH
ENV PATH="/usr/local/swift/usr/bin:$PATH"
ENV SWIFT_ROOT="/usr/local/swift"

# Verify Swift installation
RUN swift --version

# Clone swift-nio repository
RUN git clone --depth 1 https://github.com/apple/swift-nio.git

# Set working directory
WORKDIR swift-nio

# Copy build script
COPY build.sh $SRC/

# Set environment variables for OSS-Fuzz
ENV SANITIZER="address"
ENV ENGINE="libfuzzer"