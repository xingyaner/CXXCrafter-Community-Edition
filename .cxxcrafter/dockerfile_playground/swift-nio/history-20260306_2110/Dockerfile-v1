FROM gcr.io/oss-fuzz-base/base-builder@sha256:1051d1a0a51f82987e4fa36f85dd8cee525df635f8523ac35575086979625e67

ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies for Swift and the project
RUN apt-get update && apt-get install -y \
    git \
    curl \
    libatomic1 \
    libxml2 \
    libcurl4 \
    libedit2 \
    libsqlite3-0 \
    libc6-dev \
    binutils \
    libgcc-5-dev \
    libstdc++-5-dev \
    zlib1g-dev \
    libpython3.6 \
    tzdata \
    locales \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

# Install Swift toolchain (Swift 5.7+ as required by SwiftNIO)
RUN SWIFT_VERSION=5.7.3 && \
    SWIFT_PLATFORM=ubuntu20.04 && \
    SWIFT_BRANCH=swift-${SWIFT_VERSION}-release && \
    SWIFT_ARCHIVE_NAME=swift-${SWIFT_VERSION}-RELEASE-ubuntu${SWIFT_PLATFORM#ubuntu} && \
    SWIFT_URL=https://download.swift.org/${SWIFT_BRANCH}/ubuntu2004/swift-${SWIFT_VERSION}-RELEASE/${SWIFT_ARCHIVE_NAME}.tar.gz && \
    curl -fsSL ${SWIFT_URL} -o swift.tar.gz && \
    curl -fsSL ${SWIFT_URL}.sig -o swift.tar.gz.sig && \
    export GNUPGHOME="$(mktemp -d)" && \
    tar -xzf swift.tar.gz --directory / --strip-components=1 && \
    chmod -R o+r /usr/lib/swift && \
    rm -rf "$GNUPGHOME" swift.tar.gz.sig swift.tar.gz

# Set up Swift environment
ENV PATH="/usr/bin:${PATH}"
ENV SWIFT_ROOT=/usr

# Clone the SwiftNIO repository
RUN git clone --depth 1 https://github.com/apple/swift-nio.git

# Copy the build script
COPY build.sh $SRC/

# Set the working directory
WORKDIR $SRC/swift-nio