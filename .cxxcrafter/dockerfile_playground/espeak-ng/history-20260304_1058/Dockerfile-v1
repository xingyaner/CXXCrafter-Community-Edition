FROM gcr.io/oss-fuzz-base/base-builder@sha256:c099d3d710d12d5d9a39498463ff10973977d1c7a85e9a0fbe00c7f0a0fa9fb8

ENV DEBIAN_FRONTEND=noninteractive

# Install essential build dependencies for espeak-ng
RUN apt-get update && \
    apt-get install -y \
    autoconf \
    automake \
    libtool \
    pkg-config \
    make \
    g++ \
    cmake \
    git \
    wget \
    tar \
    gzip \
    bzip2 \
    xz-utils \
    python3 \
    python3-pip \
    libpcaudio-dev \
    libsonic-dev \
    libpulse-dev \
    libasound2-dev \
    libncurses5-dev \
    libncursesw5-dev \
    libmp3lame-dev \
    libmpg123-dev \
    libsndfile1-dev \
    libportaudio2 \
    portaudio19-dev \
    libopenal-dev \
    libespeak-ng-dev \
    libespeak-ng1 \
    libsonic0 \
    libsonic-dev \
    libpcaudio0 \
    libpcaudio-dev \
    libutf8proc-dev \
    libicu-dev \
    gettext \
    texinfo \
    help2man \
    groff \
    doxygen \
    graphviz \
    && rm -rf /var/lib/apt/lists/*

# Clone espeak-ng repository
RUN git clone --depth 1 https://github.com/espeak-ng/espeak-ng.git

# Copy the build script
COPY build.sh $SRC/

WORKDIR $SRC/espeak-ng